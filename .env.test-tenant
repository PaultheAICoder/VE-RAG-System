# AI Ready RAG — Test Tenant (mixed document testing)
# Port: 8504
# DB:   vaultiq_test (postgres)
#
# Usage: ./scripts/start-tenant.sh test-tenant

# ── Profile ───────────────────────────────────────────────────────────────────
ENV_PROFILE=laptop

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8504
API_BASE_URL=http://localhost:8504

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaultiq:devpassword@localhost:5432/vaultiq_test
DATABASE_BACKEND=postgresql

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_BACKEND=pgvector

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CLAUDE_BACKEND=cli

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=test-tenant-dev-secret-key-change-in-production

# ── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=npassword2002
ADMIN_DISPLAY_NAME="Test Admin"

# ── Tenant ────────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=test_tenant
TENANT_CONFIG_PATH=tenant-instances/{tenant_id}/tenant.json

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/tenants/test/uploads
FORMS_TEMPLATE_STORAGE_PATH=./data/tenants/test/form_templates

# ── Auto-tagging ──────────────────────────────────────────────────────────────
# Generic strategy — handles mixed doc types (insurance forms, financials, HR, images)
AUTO_TAGGING_ENABLED=true
AUTO_TAGGING_STRATEGY=generic
AUTO_TAGGING_PATH_ENABLED=true
AUTO_TAGGING_LLM_ENABLED=true
AUTO_TAGGING_STRATEGIES_DIR=./data/auto_tag_strategies

# ── RAGBench (isolated) ───────────────────────────────────────────────────────
RAGBENCH_DATA_DIR=./data/tenants/test/ragbench

# ── Redis (shared infra) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
