# AI Ready RAG — Insurance Agency Test Tenant
# Port: 8502
# DB:   vaultiq_insurance (postgres)
#
# Usage: ./scripts/start-tenant.sh insurance

# ── Profile ───────────────────────────────────────────────────────────────────
ENV_PROFILE=laptop

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8505
API_BASE_URL=http://localhost:8505

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaultiq:devpassword@localhost:5432/vaultiq_insurance
DATABASE_BACKEND=postgresql

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_BACKEND=pgvector

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CLAUDE_BACKEND=cli

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=insurance-dev-secret-key-change-in-production

# ── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=npassword2002
ADMIN_DISPLAY_NAME="Insurance Admin"

# ── Tenant ────────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=insurance_agency
TENANT_CONFIG_PATH=tenant-instances/{tenant_id}/tenant.json

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/tenants/insurance/uploads
FORMS_TEMPLATE_STORAGE_PATH=./data/tenants/insurance/form_templates

# ── Auto-tagging ──────────────────────────────────────────────────────────────
AUTO_TAGGING_ENABLED=true
AUTO_TAGGING_STRATEGY=insurance_agency
AUTO_TAGGING_PATH_ENABLED=true
AUTO_TAGGING_LLM_ENABLED=true
AUTO_TAGGING_STRATEGIES_DIR=./data/auto_tag_strategies

# ── RAGBench (isolated) ───────────────────────────────────────────────────────
RAGBENCH_DATA_DIR=./data/tenants/insurance/ragbench

# ── Redis (shared infra) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
