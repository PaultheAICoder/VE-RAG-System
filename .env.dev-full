# Full-feature dev environment — postgres + docling + pgvector + Claude CLI
# Usage: set -a && source .env.dev-full && set +a
#        OR just copy to .env
#
# Requires: docker compose -f docker-compose.dev.yml up -d
# System deps: sudo apt install tesseract-ocr tesseract-ocr-eng libtesseract-dev

# ── Profile ──────────────────────────────────────────────────────────────────
ENV_PROFILE=laptop

# ── Database (postgres via docker-compose.dev.yml) ───────────────────────────
DATABASE_URL=postgresql://vaultiq:devpassword@localhost:5432/vaultiq
DATABASE_BACKEND=postgresql

# ── Vector store ─────────────────────────────────────────────────────────────
VECTOR_BACKEND=pgvector

# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Claude backend (primary for ingestion, forms, and query) ─────────────────
# "cli" uses the local Claude Code session — no API key needed on laptop
CLAUDE_BACKEND=cli

# ── Auto-tagging ──────────────────────────────────────────────────────────────
AUTO_TAGGING_ENABLED=true
AUTO_TAGGING_STRATEGY=generic
AUTO_TAGGING_CREATE_MISSING_TAGS=true
AUTO_TAGGING_CONFIDENCE_THRESHOLD=0.6

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production

# ── PII encryption (leave unset to skip in dev) ───────────────────────────────
# VAULTIQ_ENCRYPTION_KEY=

# ── Tenant ────────────────────────────────────────────────────────────────────
TENANT_ID=default
