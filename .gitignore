# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env

# Data directories
chroma_db/
uploads/
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.bak
*.pptx
~$*

# Claude Code (session-specific, auto-generated)
.agents/
.claude/settings.local.json

# Claude memory (dynamic data - not committed)
.claude/memory/*.jsonl
.claude/memory/session-*.md
.claude/memory/postmortems/

# Database / runtime data (uploads, vectors, dbs)
# Use data/* (not data/) so we can whitelist subdirectories with !
data/*
!data/auto_tag_strategies/
*.db
issues/
frontend/.vite/
frontend/dist/
ai_ready_rag/static/

# Tenant instances (customer data — tracked dir, ignored contents)
tenant-instances/*/
