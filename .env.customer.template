# VaultIQ Customer Instance Configuration
# Copy to .env and fill in all required values before running docker-compose

# ─── Required ───────────────────────────────────────────────────────────────
TENANT_ID=                          # e.g. acme-corp (no spaces, lowercase)
ANTHROPIC_API_KEY=                  # sk-ant-...
POSTGRES_PASSWORD=                  # strong random password
JWT_SECRET_KEY=                     # strong random secret (min 32 chars)

# Encryption key for PII columns (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
VAULTIQ_ENCRYPTION_KEY=

# ─── Optional Overrides ─────────────────────────────────────────────────────
# ENV_PROFILE=hosted                # default: hosted
# CLAUDE_ENRICHMENT_ENABLED=true    # default: true on hosted profile
# CLAUDE_QUERY_ENABLED=true         # default: true on hosted profile
# CHAT_MODEL=qwen3-rag              # Ollama fallback model
