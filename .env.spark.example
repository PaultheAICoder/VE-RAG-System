# AI Ready RAG - Spark Production Profile
# Copy to .env and modify as needed
#
# Requires: PostgreSQL + Redis running (bare metal or Docker)

# ── Profile ──────────────────────────────────────────────────────────────────
ENV_PROFILE=spark

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaultiq:CHANGEME@localhost:5432/vaultiq
DATABASE_BACKEND=postgresql

# ── Vector store ─────────────────────────────────────────────────────────────
VECTOR_BACKEND=pgvector

# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Claude backend (primary for ingestion, forms, and query) ─────────────────
# Use "api" with ANTHROPIC_API_KEY for production, or "cli" for DGX w/ Claude Code
CLAUDE_BACKEND=api
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-secure-random-key-here

# ── Tenant ────────────────────────────────────────────────────────────────────
TENANT_ID=default

# ── Profile defaults (no need to set unless overriding): ─────────────────────
# CHUNKER_BACKEND=docling
# ENABLE_OCR=true
# CHAT_MODEL=qwen3-rag              (fallback LLM when Claude unavailable)
# EMBEDDING_MODEL=nomic-embed-text  (always Ollama — Claude doesn't embed)
# FORMS_OCR_ENGINE=paddleocr
# RAG_MAX_CONTEXT_TOKENS=6000
# RAG_MAX_RESPONSE_TOKENS=2048
