# AI Ready RAG - Laptop Development Profile
# Copy to .env (or use .env.dev-full for full-feature dev)
#
# Requires: docker compose -f docker-compose.dev.yml up -d
# System deps: sudo apt install tesseract-ocr tesseract-ocr-eng libtesseract-dev

# ── Profile ──────────────────────────────────────────────────────────────────
ENV_PROFILE=laptop

# ── Database (postgres via docker-compose.dev.yml) ───────────────────────────
DATABASE_URL=postgresql://vaultiq:devpassword@localhost:5432/vaultiq
DATABASE_BACKEND=postgresql

# ── Vector store ─────────────────────────────────────────────────────────────
VECTOR_BACKEND=pgvector

# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Claude backend (primary for ingestion, forms, and query) ─────────────────
# "cli" uses the local Claude Code session — no API key needed
CLAUDE_BACKEND=cli

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production

# ── Tenant ────────────────────────────────────────────────────────────────────
TENANT_ID=default

# ── Profile defaults (no need to set unless overriding): ─────────────────────
# CHUNKER_BACKEND=docling
# ENABLE_OCR=true
# CHAT_MODEL=llama3.2:latest        (fallback LLM when Claude unavailable)
# EMBEDDING_MODEL=nomic-embed-text  (always Ollama — Claude doesn't embed)
# FORMS_OCR_ENGINE=tesseract        (tesseract on laptop, paddleocr on Spark)
# RAG_MAX_CONTEXT_TOKENS=2000       (smaller than Spark due to hardware limits)
