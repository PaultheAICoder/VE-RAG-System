# AI Ready RAG — Law Firm Test Tenant
# Port: 8503
# DB:   vaultiq_lawfirm (postgres)
#
# Usage: ./scripts/start-tenant.sh lawfirm

# ── Profile ───────────────────────────────────────────────────────────────────
ENV_PROFILE=laptop

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8503
API_BASE_URL=http://localhost:8503

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaultiq:devpassword@localhost:5432/vaultiq_lawfirm
DATABASE_BACKEND=postgresql

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_BACKEND=pgvector

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CLAUDE_BACKEND=cli

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=lawfirm-dev-secret-key-change-in-production

# ── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=npassword2002
ADMIN_DISPLAY_NAME="Law Firm Admin"

# ── Tenant ────────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=law_firm
TENANT_CONFIG_PATH=tenant-instances/{tenant_id}/tenant.json

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/tenants/lawfirm/uploads
FORMS_TEMPLATE_STORAGE_PATH=./data/tenants/lawfirm/form_templates

# ── Auto-tagging ──────────────────────────────────────────────────────────────
AUTO_TAGGING_ENABLED=true
AUTO_TAGGING_STRATEGY=law_firm
AUTO_TAGGING_PATH_ENABLED=true
AUTO_TAGGING_LLM_ENABLED=true
AUTO_TAGGING_STRATEGIES_DIR=./data/auto_tag_strategies

# ── RAGBench (isolated) ───────────────────────────────────────────────────────
RAGBENCH_DATA_DIR=./data/tenants/lawfirm/ragbench

# ── Redis (shared infra) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
